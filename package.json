{
  "name": "pi-spec-flow",
  "version": "0.4.0",
  "description": "Pi extension that turns a technical spec into structured implementation tickets stored as Markdown files.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "src/",
    "skills/planning-methodology/",
    "skills/spec-flow-implementation-protocol/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-extension",
    "spec",
    "tickets",
    "planning",
    "task-breakdown"
  ],
  "license": "MIT",
  "author": {
    "name": "Lean Cabrera",
    "url": "https://github.com/leandr0ck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leandr0ck/pi-spec-flow.git"
  },
  "bugs": {
    "url": "https://github.com/leandr0ck/pi-spec-flow/issues"
  },
  "homepage": "https://github.com/leandr0ck/pi-spec-flow#readme",
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.3",
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@earendil-works/pi-tui": "^0.79.3",
    "@types/node": "^25.9.3",
    "typebox": "^1.2.10",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
